<div class="container-fluid py-4">
  <div class="row">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 mb-0">Edit Search Template</h1>
        <%= link_to "Back to Search Templates", saved_searches_path, class: "btn btn-outline-secondary" %>
      </div>

      <div class="card">
        <div class="card-body">
          <%= form_with model: @saved_search, local: true, class: "row g-3" do |form| %>
            <% if @saved_search.errors.any? %>
              <div class="col-12">
                <div class="alert alert-danger" role="alert">
                  <h4>Please fix the following errors:</h4>
                  <ul class="mb-0">
                    <% @saved_search.errors.full_messages.each do |message| %>
                      <li><%= message %></li>
                    <% end %>
                  </ul>
                </div>
              </div>
            <% end %>

            <div class="col-12">
              <%= form.label :name, class: "form-label" %>
              <%= form.text_field :name, class: "form-control", placeholder: "Enter a name for your search template" %>
            </div>
            <% if is_admin? %>
              <div class="col-12">
                <div class="form-check">
                  <%= form.check_box :global, class: "form-check-input" %>
                  <%= form.label :global, "Make this a curated search (visible to all users)", class: "form-check-label" %>
                </div>
              </div>
            <% end %>

            <div>
              <%= form.submit "Update Search Template", class: "btn btn-primary" %>
              <%= link_to "Cancel", saved_searches_path, class: "link_to" %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Display search details (read-only) -->
      <div class="card mt-4">
        <div class="card-header">
          <h5 class="mb-0">Search Template Details</h5>
        </div>
        <div class="card-body">
          <div class="row">
            <div class="col-md-6">
              <p><strong>Created:</strong> <%= @saved_search.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
              <p><strong>Created by:</strong> <%= @saved_search.user&.email || 'Unknown' %></p>
              <% if @saved_search.global %>
                <p><strong>Type:</strong> <span class="badge bg-success">Curated Search Template</span></p>
              <% end %>
            </div>
            <div class="col-md-6">
              <p><strong>Filters:</strong></p>
              <div class="bg-light p-3 rounded">
                <% if @saved_search.filters.present? %>
                  <%= render "search_parameters", saved_search: @saved_search %>
                <% else %>
                  <span class="text-muted">No search parameters</span>
                <% end %>
              </div>
            </div>
          </div>
          
          <div class="mt-3">
            <%= link_to "Run This Searc", search_items_path(q: @saved_search.search_params), class: "btn btn-primary" %>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>