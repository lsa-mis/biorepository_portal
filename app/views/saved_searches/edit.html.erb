<div class="container-fluid py-4">
  <div class="row">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 mb-0">Edit Saved Search</h1>
        <%= link_to "Back to Saved Searches", saved_searches_path, class: "btn btn-outline-secondary" %>
      </div>

      <div class="card">
        <div class="card-body">
          <%= form_with model: @saved_search, local: true, class: "row g-3" do |form| %>
            <% if @saved_search.errors.any? %>
              <div class="col-12">
                <div class="alert alert-danger" role="alert">
                  <h4>Please fix the following errors:</h4>
                  <ul class="mb-0">
                    <% @saved_search.errors.full_messages.each do |message| %>
                      <li><%= message %></li>
                    <% end %>
                  </ul>
                </div>
              </div>
            <% end %>

            <div class="col-12">
              <%= form.label :name, class: "form-label" %>
              <%= form.text_field :name, class: "form-control", placeholder: "Enter a name for your saved search" %>
            </div>

            <div class="col-12">
              <div class="d-flex gap-2">
                <%= form.submit "Update Search", class: "btn btn-primary" %>
                <%= link_to "Cancel", saved_searches_path, class: "btn btn-secondary" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Display search details (read-only) -->
      <div class="card mt-4">
        <div class="card-header">
          <h5 class="mb-0">Search Details</h5>
        </div>
        <div class="card-body">
          <div class="row">
            <div class="col-md-6">
              <p><strong>Created:</strong> <%= @saved_search.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
              <p><strong>Created by:</strong> <%= @saved_search.user&.email || 'Unknown' %></p>
              <% if @saved_search.global %>
                <p><strong>Type:</strong> <span class="badge bg-success">Global Search</span></p>
              <% end %>
            </div>
            <div class="col-md-6">
              <p><strong>Search Parameters:</strong></p>
              <div class="bg-light p-3 rounded">
                <% if @saved_search.search_params.present? %>
                  <% @saved_search.search_params.each do |key, value| %>
                    <% if value.present? && value != "" %>
                      <div class="mb-1">
                        <strong><%= key.humanize %>:</strong> 
                        <span class="text-muted"><%= value.is_a?(Hash) ? value.to_json : value %></span>
                      </div>
                    <% end %>
                  <% end %>
                <% else %>
                  <span class="text-muted">No search parameters</span>
                <% end %>
              </div>
            </div>
          </div>
          
          <div class="mt-3">
            <%= link_to "Run This Search", search_items_path(q: @saved_search.search_params), class: "btn btn-outline-primary" %>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>