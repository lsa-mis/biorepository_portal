<div class="container-fluid py-4">
  <div class="row">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 mb-0">My Saved Searches</h1>
        <%= link_to "New Search", search_items_path, class: "btn btn-primary" %>
      </div>

      <% if @saved_searches.any? %>
        <div class="row">
          <% @saved_searches.each do |saved_search| %>
            <div class="col-md-6 col-lg-4 mb-4">
              <div class="card h-100">
                <div class="card-body d-flex flex-column">
                  <h5 class="card-title">
                    <%= link_to saved_search.name, search_items_path(q: saved_search.search_params), class: "text-decoration-none" %>
                  </h5>
                  
                  <% if saved_search.description.present? %>
                    <p class="card-text text-muted">
                      <%= truncate(saved_search.description, length: 100) %>
                    </p>
                  <% end %>
                  
                  <div class="card-text">
                    <small class="text-muted">
                      Created <%= time_ago_in_words(saved_search.created_at) %> ago
                    </small>
                  </div>

                  <div class="card-text">
                    <small class="text-info">
                      <%= pluralize(saved_search.search_params.keys.count { |key| saved_search.search_params[key].present? }, 'filter') %> applied
                    </small>
                  </div>

                  <div class="mt-auto pt-3">
                    <div class="btn-group w-100" role="group">
                      <%= link_to "Run Search", search_items_path(q: saved_search.search_params), 
                          class: "btn btn-sm btn-outline-primary" %>
                      <%= link_to "View Details", saved_search_path(saved_search), 
                          class: "btn btn-sm btn-outline-secondary" %>
                      <%= button_to "Delete", saved_search_path(saved_search), 
                          method: :delete, 
                          class: "btn btn-sm btn-outline-danger",
                          confirm: "Are you sure you want to delete this saved search?",
                          data: { turbo: "false" } %>
                    </div>
                  </div>
                </div>

                <% if saved_search.global %>
                  <div class="card-footer bg-success text-white text-center">
                    <small><i class="fas fa-globe"></i> Global Search</small>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

        <div class="mt-4">
          <p class="text-muted">
            <strong><%= pluralize(@saved_searches.count, 'saved search') %></strong> total
          </p>
        </div>

      <% else %>
        <div class="text-center py-5">
          <div class="mb-4">
            <i class="fas fa-search fa-3x text-muted"></i>
          </div>
          <h3 class="text-muted">No Saved Searches Yet</h3>
          <p class="text-muted mb-4">
            Save your favorite search queries to easily access them later.
          </p>
          <div class="d-flex justify-content-center gap-3">
            <%= link_to "Start Searching", search_items_path, class: "btn btn-primary" %>
            <%= link_to "Learn More", "#", class: "btn btn-outline-secondary" %>
          </div>
        </div>
      <% end %>

    </div>
  </div>
</div>

<!-- Search Filters Summary Modal (for detailed view) -->
<div class="modal fade" id="filtersModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Search Filters</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div id="modalContent">
          <!-- Dynamic content will be loaded here -->
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<script>
  // Function to show search parameters in modal
  function showFilters(searchParams) {
    const modal = new bootstrap.Modal(document.getElementById('filtersModal'));
    const content = document.getElementById('modalContent');
    
    let html = '<div class="row">';
    
    Object.keys(searchParams).forEach(key => {
      if (searchParams[key] && searchParams[key] !== '' && JSON.stringify(searchParams[key]) !== '{}') {
        html += `
          <div class="col-md-6 mb-3">
            <strong class="text-capitalize">${key.replace(/_/g, ' ')}:</strong><br>
            <span class="text-muted">${JSON.stringify(searchParams[key])}</span>
          </div>
        `;
      }
    });
    
    html += '</div>';
    content.innerHTML = html || '<p class="text-muted">No active filters</p>';
    modal.show();
  }
</script>
