<div class="container-fluid py-4">
  <div class="row">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 mb-0">My Saved Searches</h1>
        <%= link_to "New Search", search_items_path, class: "btn btn-primary" %>
      </div>

      <% if @saved_searches.any? %>
        <div class="table-responsive">
          <table class="table text-center mt-4">
            <thead class="table-group-divider">
              <tr>
                <th scope="col" class="text-start">Name</th>
                <th scope="col" class="text-start">Created At</th>
                <th scope="col" class="text-start">Created By</th>
                <th scope="col" class="text-start">Edit</th>
                <th scope="col" class="text-start">Run</th>
              </tr>
            </thead>
            <tbody class="table-group-divider">
              <% @saved_searches.each do |saved_search| %>
                <tr>
                  <td class="text-start">
                    <div>
                      <strong><%= saved_search.name %></strong>
                      <% if saved_search.global %>
                        <span class="badge bg-success ms-2">
                          <i class="fas fa-globe"></i> Global
                        </span>
                      <% end %>
                    </div>
                    <% if saved_search.description.present? %>
                      <div class="text-muted small">
                        <%= truncate(saved_search.description, length: 80) %>
                      </div>
                    <% end %>
                  </td>
                  <td class="text-start">
                    <%= saved_search.created_at.strftime("%b %d, %Y") %>
                    <div class="text-muted small">
                      <%= time_ago_in_words(saved_search.created_at) %> ago
                    </div>
                  </td>
                  <td class="text-start">
                    <%= saved_search.user&.email || 'Unknown' %>
                  </td>
                  <td class="text-start">
                    <%= link_to "Edit", edit_saved_search_path(saved_search), 
                        class: "btn btn-sm btn-outline-secondary" %>
                  </td>
                  <td class="text-start">
                    <%= link_to "Run", search_items_path(q: saved_search.search_params), 
                        class: "btn btn-sm btn-primary" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <div class="mt-4">
          <p class="text-muted">
            <strong><%= pluralize(@saved_searches.count, 'saved search') %></strong> total
          </p>
        </div>

      <% else %>
        <div class="text-center py-5">
          <div class="mb-4">
            <i class="fas fa-search fa-3x text-muted"></i>
          </div>
          <h3 class="text-muted">No Saved Searches Yet</h3>
          <p class="text-muted mb-4">
            Save your favorite search queries to easily access them later.
          </p>
          <div class="d-flex justify-content-center gap-3">
            <%= link_to "Start Searching", search_items_path, class: "btn btn-primary" %>
            <%= link_to "Learn More", "#", class: "btn btn-outline-secondary" %>
          </div>
        </div>
      <% end %>

    </div>
  </div>
</div>

